{
  "name": "@andersonlucasp/components",
  "version": "0.1.0",
  "description": "Web Components for Momentum DS using Stencil",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/momentum-ds/momentum-ds.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./css": "./dist/momentum-ds/momentum-ds.css",
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --noEmit",
    "lint": "echo 'Linting components...'"
  },
  "dependencies": {
    "@andersonlucasp/tokens": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "web-components",
    "design-system",
    "stencil",
    "momentum"
  ],
  "author": "Lucas Anderson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andersonlucasp/momentum-ds.git",
    "directory": "packages/components"
  }
}
