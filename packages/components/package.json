{
  "name": "@andersonlucasp/components",
  "version": "0.1.0",
  "description": "Web Components for Momentum DS using Stencil",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/momentum-ds/momentum-ds.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./css": "./dist/momentum-ds/momentum-ds.css",
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs"
    }
  },
  "scripts": {
    "build": "stencil build --prod",
    "build:dev": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec",
    "test:e2e": "stencil test --e2e",
    "test:watch": "stencil test --spec --watch",
    "generate": "stencil generate",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@andersonlucasp/tokens": "workspace:*"
  },
  "devDependencies": {
    "@stencil/angular-output-target": "^0.8.4",
    "@stencil/core": "^4.20.0",
    "@stencil/react-output-target": "^0.8.4",
    "@stencil/vue-output-target": "^0.8.4",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.1.5",
    "@types/jest": "^29.5.11",
    "axe-core": "^4.8.2",
    "jest": "^29.7.0",
    "jest-axe": "^8.0.0",
    "puppeteer": "^21.6.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "web-components",
    "design-system",
    "stencil",
    "momentum"
  ],
  "author": "Lucas Anderson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andersonlucasp/momentum-ds.git",
    "directory": "packages/components"
  }
}
