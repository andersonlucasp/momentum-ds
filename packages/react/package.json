{
  "name": "@andersonlucasp/react",
  "version": "0.1.0",
  "description": "React wrappers for Momentum DS web components",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@andersonlucasp/components": "*"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "react",
    "web-components",
    "design-system",
    "momentum"
  ],
  "author": "Lucas Anderson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andersonlucasp/momentum-ds.git",
    "directory": "packages/react"
  }
}
